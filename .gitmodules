[submodule "libs/ViruaPPU"]
	path = libs/ViruaPPU
	url = https://github.com/MatheoVignaud/VirtuaPPU-experimental.git
	# The xmake build auto-applies port/patches/viruappu-*.patch into
	# this submodule (HDMA per-line hook + mosaic register), which
	# permanently dirties the working tree. Ignore the dirty state here
	# so the parent repo's `git status` stays clean; bumps to the pinned
	# submodule commit are still tracked normally.
	ignore = dirty
[submodule "libs/VirtuaAPU"]
	path = libs/VirtuaAPU
	url = https://github.com/MatheoVignaud/VirtuaAPU.git
	ignore = dirty