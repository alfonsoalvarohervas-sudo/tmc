# Copyrighted ROM, extracted assets, and per-user runtime state.
# These must NOT be committed to the public repository.
baserom.gba
*.sav
run/
config.json
release/

# Regenerable diagnostic capture (TMC_ROOMCAP harness default output). Contains a
# rendered copyrighted ROM frame; never commit. The harness recreates it on demand.
roomcap.png

# Discord Rich Presence application ID — per-developer/release secret-by-policy
# (technically public-by-design, but we don't want forks to inherit our app).
# xmake reads this if present and bakes the ID into the local build.
discord_app_id.txt

# Per-user runtime state (randomizer seed/state + soft save slots) and F9 bug
# captures (screenshots + save.bin). Same runtime-local policy as *.sav / run/
# above — these must NOT be committed to the public repository.
tmc*.randomizer
tmc.softslots
bugreport_*/
state_auto_*.bin

# tools/ build-dependency install prefix: fmt / nlohmann_json / CLI11 are fetched
# and compiled by tools/CMakeLists.txt (FetchContent) into these dirs.
tools/include/
tools/lib/

# Matching retail maps from upstream zeldaret/tmc (for per-region address derivation)
tools/retail_maps/

# Temporary build/run artifacts
.tmp/
